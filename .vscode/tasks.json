{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "watch",
      "isBackground": true,
      "presentation": {
        "reveal": "never"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": {
        "owner": "typescript",
        "fileLocation": "relative",
        "pattern": {
          "regexp": "^(.*):(\\d+):(\\d+):\\s+(error|warning):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "\\[watch\\] build started",
          "endsPattern": "\\[watch\\] build finished"
        }
      }
    },
    {
      "label": "temp-confirm-location-branch",
      "type": "shell",
      "command": "pwsh",
      "args": ["Get-Location; git branch --show-current"],
      "isBackground": false
    },
    {
      "label": "temp-git-config-name",
      "type": "shell",
      "command": "git",
      "args": ["config", "user.name"],
      "isBackground": false
    },
    {
      "label": "temp-git-status-short",
      "type": "shell",
      "command": "git",
      "args": ["status", "--short"],
      "isBackground": false
    },
    {
      "label": "temp-git-diff-stat",
      "type": "shell",
      "command": "git",
      "args": ["diff", "--stat"],
      "isBackground": false
    },
    {
      "label": "temp-git-diff-tasks",
      "type": "shell",
      "command": "git",
      "args": ["diff", ".vscode/tasks.json"],
      "isBackground": false
    }
  ]
}
